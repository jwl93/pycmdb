{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]+$"
    },
    "description": {
      "type": "string"
    },
    "members": {
      "type": "array",
      "items": { "type": "string" }
    },
    "variables": {
      "type": "object"
    },
    "vars": {
      "type": "object"
    }
  }
}
