{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["hostname", "ip"],
  "properties": {
    "hostname": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]+$",
      "examples": ["web-01", "db-primary"]
    },
    "ip": {
      "type": "string",
      "format": "ipv4"
    },
    "host_group": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "default": ["untagged"]
    },
    "ssh": {
      "type": "object",
      "properties": {
        "port": { "type": "integer", "default": 22 },
        "user": { "type": "string", "default": "root" },
        "key_file": { "type": "string" }
      }
    },
    "labels": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "vars": {
      "type": "object"
    }
  }
}
